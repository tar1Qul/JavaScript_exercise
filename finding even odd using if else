<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>js</title>
</head>
<body> 
    <script>

            let num = parseFloat(prompt("Enter a number:"));

            if (num %2 === 0){
                document.write("<h2>" + num + " is even.</h2>");
            } else {
                document.write("<h2>" + num + " is odd.</h2>");
            }
            
     
    </script>
</body>
</html>
