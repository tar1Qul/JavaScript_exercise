
    <script>

            let num = parseFloat(prompt("Enter a number:"));

            if (num > 0){
                document.write("<h2>" + num + " is positive number.</h2>");
            } else if (num < 0){
                document.write("<h2>" + num + " is negative number.</h2>");
            } else {
                document.write("<h2>" + num + " is zero.</h2>");
            }
            
     
    </script>
