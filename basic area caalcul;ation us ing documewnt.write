<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>js</title>
</head>
<body> 
    <script>

            //  input for square
            let hight1 = parseFloat(prompt("Enter hight for square:"));
            let base1 = parseFloat(prompt("Enter base for square:"));
            let squareArea = hight1 * base1;

           document.write("</br> Area of square is: ", squareArea);

            //  input for rectangle
            let hight2 = parseFloat(prompt("Enter hight for rectangle:"));
            let base2 = parseFloat(prompt("Enter base for rectangle:"));
            let rectangleArea = hight2 * base2;

            document.write("</br> Area of rectangle is: ", rectangleArea);

            //  input for triangle
            let hight3 = parseFloat(prompt("Enter hight for triangle:"));
            let base3 = parseFloat(prompt("Enter base for triangle:"));
            let triangleArea = 0.5 * hight3 * base3;

            document.write("</br> Area of triangle is: ", triangleArea);

            //  input for circle
            let radius = parseFloat(prompt("Enter radius for circle:"));
            let circleArea = Math.PI * radius * radius;

            document.write("</br> Area of circle is: ", circleArea);
     
    </script>
</body>
</html>
